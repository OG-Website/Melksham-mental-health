"""
API Integrations - Free APIs for enhanced content
No API keys required for these free services!
"""

import requests
import json
import random
from typing import List, Dict, Optional
import time

class APIContentFetcher:
    """Fetch content from free APIs to enhance our database"""
    
    def __init__(self):
        self.session = requests.Session()
        self.session.headers.update({
            'User-Agent': 'MelkshamMentalHealth/1.0'
        })
    
    # ============================================
    # QUOTES API - ZenQuotes (Free, No Key)
    # ============================================
    
    def fetch_inspirational_quotes(self, count=50) -> List[Dict]:
        """Fetch inspirational quotes from ZenQuotes API"""
        quotes = []
        
        try:
            # ZenQuotes - Free, no key needed
            url = "https://zenquotes.io/api/quotes"
            response = self.session.get(url, timeout=10)
            
            if response.status_code == 200:
                data = response.json()
                for item in data[:count]:
                    quotes.append({
                        'text': item. get('q', ''),
                        'author': item.get('a', 'Unknown'),
                        'source': 'ZenQuotes',
                        'topics': ['Inspiration', 'Motivation', 'General'],
                        'audience': ['adults', 'teens', 'general']
                    })
                print(f"✓ Fetched {len(quotes)} quotes from ZenQuotes")
        except Exception as e:
            print(f"Warning: Could not fetch from ZenQuotes: {e}")
        
        return quotes
    
    def fetch_quotable_quotes(self, count=50) -> List[Dict]:
        """Fetch quotes from Quotable API"""
        quotes = []
        
        try:
            # Quotable API - Free, no key
            for _ in range(min(count, 50)):  # Rate limit consideration
                url = "https://api.quotable.io/random? tags=inspirational|wisdom|life"
                response = self.session.get(url, timeout=10)
                
                if response. status_code == 200:
                    data = response.json()
                    quotes.append({
                        'text': data. get('content', ''),
                        'author': data.get('author', 'Unknown'),
                        'source': 'Quotable',
                        'topics':  data.get('tags', ['General']),
                        'audience': ['adults', 'general']
                    })
                
                time.sleep(0.5)  # Be nice to the API
            
            print(f"✓ Fetched {len(quotes)} quotes from Quotable")
        except Exception as e:
            print(f"Warning: Could not fetch from Quotable: {e}")
        
        return quotes
    
    # ============================================
    # ADVICE API - Advice Slip (Free, No Key)
    # ============================================
    
    def fetch_advice_slips(self, count=50) -> List[Dict]:
        """Fetch life advice from Advice Slip API"""
        advice_list = []
        
        try: 
            for _ in range(min(count, 50)):
                url = "https://api.adviceslip.com/advice"
                response = self.session.get(url, timeout=10)
                
                if response. status_code == 200:
                    data = response.json()
                    advice_text = data.get('slip', {}).get('advice', '')
                    
                    if advice_text: 
                        advice_list.append({
                            'title': 'Life Advice',
                            'content': advice_text,
                            'topics': ['General', 'Life Skills', 'Wellbeing'],
                            'audience': ['adults', 'teens', 'general'],
                            'evidence': 'General life wisdom'
                        })
                
                time.sleep(2)  # API requirement - 2 second delay
            
            print(f"✓ Fetched {len(advice_list)} advice pieces from Advice Slip")
        except Exception as e:
            print(f"Warning: Could not fetch from Advice Slip: {e}")
        
        return advice_list
    
    # ============================================
    # AFFIRMATIONS API - Custom generation
    # ============================================
    
    def generate_affirmations(self, count=100) -> List[Dict]:
        """Generate mental health affirmations"""
        
        templates = [
            "I am worthy of {value}",
            "I choose to {action} today",
            "My {quality} is enough",
            "I release {negative} and embrace {positive}",
            "I am {adjective} and {adjective2}",
            "Today I will {action} with {quality}",
            "I honor my {thing}",
            "I am learning to {action}",
            "My {quality} matters",
            "I give myself permission to {action}"
        ]
        
        values = ["love", "respect", "happiness", "peace", "kindness", "compassion"]
        actions = ["be kind to myself", "rest", "ask for help", "set boundaries", 
                  "prioritize my wellbeing", "take small steps", "be patient", "practice self-care"]
        qualities = ["feelings", "journey", "progress", "efforts", "needs", "boundaries", "pace"]
        negatives = ["guilt", "shame", "fear", "doubt", "worry", "perfectionism"]
        positives = ["acceptance", "hope", "courage", "self-compassion", "growth", "healing"]
        adjectives = ["strong", "capable", "resilient", "worthy", "enough", "valuable", 
                     "deserving", "brave", "important", "loved"]
        things = ["feelings", "needs", "boundaries", "journey", "mental health", "wellbeing"]
        
        affirmations = []
        
        for _ in range(count):
            template = random.choice(templates)
            
            affirmation = template.format(
                value=random.choice(values),
                action=random.choice(actions),
                quality=random.choice(qualities),
                negative=random.choice(negatives),
                positive=random.choice(positives),
                adjective=random.choice(adjectives),
                adjective2=random.choice([a for a in adjectives if a != random.choice(adjectives)]),
                thing=random.choice(things)
            )
            
            affirmations.append({
                'text': affirmation,
                'topics': ['Self-compassion', 'Affirmations', 'Wellbeing'],
                'audience': ['adults', 'teens', 'general']
            })
        
        print(f"✓ Generated {len(affirmations)} affirmations")
        return affirmations
    
