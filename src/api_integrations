    # ============================================
    # AGGREGATE ALL CONTENT
    # ============================================
    
    def fetch_all_content(self) -> Dict[str, List[Dict]]: 
        """Fetch and aggregate all content from APIs"""
        print("\n🌐 Fetching content from free APIs...")
        print("=" * 60)
        
        all_content = {
            'quotes': [],
            'advice': [],
            'affirmations': [],
            'educational': []
        }
        
        # Fetch quotes from multiple sources
        print("\n📝 Fetching quotes...")
        all_content['quotes']. extend(self.fetch_inspirational_quotes(25))
        time.sleep(1)
        all_content['quotes'].extend(self.fetch_quotable_quotes(25))
        
        # Fetch advice
        print("\n💡 Fetching advice...")
        all_content['advice']. extend(self.fetch_advice_slips(30))
        
        # Generate affirmations
        print("\n✨ Generating affirmations...")
        all_content['affirmations']. extend(self.generate_affirmations(100))
        
        # Get NHS content
        print("\n🏥 Loading NHS information...")
        all_content['educational']. extend(self.fetch_nhs_conditions())
        
        print("\n" + "=" * 60)
        print("✓ Content fetching complete!")
        print(f"  Total Quotes: {len(all_content['quotes'])}")
        print(f"  Total Advice: {len(all_content['advice'])}")
        print(f"  Total Affirmations: {len(all_content['affirmations'])}")
        print(f"  Total Educational: {len(all_content['educational'])}")
        print("=" * 60 + "\n")
        
        return all_content


def merge_with_existing_content(api_content: Dict, existing_data_dir='data'):
    """Merge API content with existing manual content"""
    from pathlib import Path
    import json
    
    data_dir = Path(existing_data_dir)
    
    for content_type, items in api_content.items():
        filename = f"{content_type}.json"
        filepath = data_dir / filename
        
        # Load existing
        existing = []
        if filepath.exists():
            try:
                with open(filepath, 'r', encoding='utf-8') as f:
                    existing = json. load(f)
            except: 
                pass
        
        # Merge (avoid duplicates)
        existing_texts = {item. get('text', item.get('content', '')) for item in existing}
        
        for new_item in items:
            new_text = new_item.get('text', new_item.get('content', ''))
            if new_text and new_text not in existing_texts:
                existing.append(new_item)
                existing_texts.add(new_text)
        
        # Save merged content
        with open(filepath, 'w', encoding='utf-8') as f:
            json.dump(existing, f, indent=2, ensure_ascii=False)
        
        print(f"✓ Merged and saved {len(existing)} items to {filename}")


