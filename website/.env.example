# Stripe Configuration (for license purchases)
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# License Product ID (create in Stripe Dashboard)
# Create a product with price GBP 20.00 (one-time payment)
STRIPE_LICENSE_PRICE_ID=price_your_price_id_here

# Email Configuration
# Public contact email shown across the website.
NEXT_PUBLIC_CONTACT_EMAIL=hello@melksham-mentalhealth.us
# Server-side contact/support email used in transactional messages.
CONTACT_EMAIL=hello@melksham-mentalhealth.us
# Optional sender address override for all providers.
MAIL_FROM_EMAIL=Melksham Mental Health <hello@melksham-mentalhealth.us>

# Resend (optional)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Melksham Mental Health <noreply@melksham-mentalhealth.us>

# SMTP (optional - used when RESEND_API_KEY is not set, or as fallback if Resend fails)
SMTP_HOST=smtp.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@melksham-mentalhealth.us
SMTP_PASSWORD=replace-with-app-password
# Optional sender override for SMTP specifically
# SMTP_FROM_EMAIL=Melksham Mental Health <hello@melksham-mentalhealth.us>

# Analytics (optional)
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Database
# Required in production for portal member accounts.
DATABASE_URL=postgresql://user:password@host:5432/database

# Members Portal

# Session encryption secret - required in production and should be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-this-with-a-random-string-of-at-least-32-chars

# Admin account credentials.
# ADMIN_EMAIL:          the admin login email address.
# ADMIN_PASSWORD_HASH:  bcrypt hash of the admin password.
#   Generate with: cd website && node scripts/create-admin-hash.mjs 'YourPassword'
#
#   IMPORTANT: bcrypt hashes contain $ signs which dotenv-expand would treat as
#   variable references. Always escape them with a backslash in .env.local files:
#
#     ADMIN_PASSWORD_HASH=\$2b\$12\$abc...   <- correct for .env.local / .env
#
#   In the Vercel dashboard, paste the raw hash without escaping:
#
#     $2b$12$abc...                          <- correct for Vercel UI
#
# ADMIN_NAME:           display name shown in the portal (optional).
ADMIN_EMAIL=hello@tradeathem.co.uk
# Generate hash with: cd website && node scripts/create-admin-hash.mjs 'YourPassword'
# Then paste the raw hash (no backslashes) into the Vercel dashboard.
# A built-in default is used automatically when this variable is unset or invalid.
ADMIN_PASSWORD_HASH=\$2b\$12\$JdbYVuAuLAZXHt6VwH88O.MdPzOCuP4PmCsZUrvl8EVCAOlbZEYBa
ADMIN_NAME=Rob Johnston

# (Optional) Path to the JSON file used to store member accounts in local development or migration tasks.
# Defaults to data/portal-users.json.
# Production portal auth requires DATABASE_URL and does not use file fallback.
# USERS_DATA_PATH=/custom/path/to/users.json

# (Optional) Path to the JSON file used to store member help messages.
# Defaults to data/help-messages.json in development and
# /tmp/mmh-help.json in production unless you override it.
# HELP_DATA_PATH=/custom/path/to/help-messages.json
