# Stripe Configuration (for license purchases)
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# License Product ID (create in Stripe Dashboard)
# Create a product with price £20.00 GBP (one-time payment)
STRIPE_LICENSE_PRICE_ID=price_your_price_id_here

# Email Configuration (optional - for contact form and license delivery)
# Sign up at https://resend.com or use alternative email service
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=help@melksham-mentalhealth.us

# Analytics (optional)
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Database (optional - for community stories and blog)
# Use for production when implementing backend features
DATABASE_URL=postgresql://user:password@host:5432/database

# ─── Members Portal ───────────────────────────────────────────────────────────

# Session encryption secret — MUST be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-this-with-a-random-string-of-at-least-32-chars

# Admin account credentials.
# ADMIN_EMAIL:          the admin login email address.
# ADMIN_PASSWORD_HASH:  bcrypt hash of the admin password.
#   Generate with: cd website && node scripts/create-admin-hash.mjs 'YourPassword'
#   IMPORTANT: wrap the hash in SINGLE QUOTES to prevent $ expansion:
#   ADMIN_PASSWORD_HASH='$2b$12$...'   ← correct
#   ADMIN_PASSWORD_HASH=$2b$12$...     ← WRONG (Vercel vars don't need quotes)
# ADMIN_NAME:           display name shown in the portal (optional).
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD_HASH='bcrypt-hash-goes-here-in-single-quotes-for-dotenv'
ADMIN_NAME=Rob Johnston

# (Optional) Path to the JSON file used to store member accounts.
# Defaults to  data/portal-users.json  in development and
#              /tmp/mmh-users.json  on Vercel (ephemeral — use a real DB for production).
# USERS_DATA_PATH=/custom/path/to/users.json
