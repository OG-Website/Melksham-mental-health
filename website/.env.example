# Stripe Configuration (for license purchases)
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# License Product ID (create in Stripe Dashboard)
# Create a product with price £20.00 GBP (one-time payment)
STRIPE_LICENSE_PRICE_ID=price_your_price_id_here

# Email Configuration (optional - for contact form and license delivery)
# Sign up at https://resend.com or use alternative email service
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=help@melksham-mentalhealth.us

# Analytics (optional)
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Database (optional - for community stories and blog)
# Use for production when implementing backend features
DATABASE_URL=postgresql://user:password@host:5432/database
